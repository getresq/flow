{
  "version": 1,
  "id": "mail-pipeline",
  "name": "Gmail Integration",
  "telemetry": {
    "log_events": ["flow_event"],
    "queue_prefixes": ["rrq:queue:mail-"],
    "function_prefixes": ["handle_mail_"],
    "worker_prefixes": ["mail_"],
    "step_prefixes": [
      "backfill-worker.",
      "incoming-schedule-process.",
      "incoming-worker.",
      "analyze-decision.",
      "draft-reply.",
      "autosend-decision.",
      "extract-worker.",
      "send-process."
    ],
    "span_prefixes": ["handle_mail_"],
    "span_names": ["insert_reply_draft"]
  },
  "keep_context": {
    "parent_spans": true,
    "root_spans": true,
    "error_events": true,
    "unmapped_events_for_kept_traces": true
  }
}
